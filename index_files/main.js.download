  window.addEventListener("scrollEvent", (e) => {
    const { target, way, from } = e.detail;
    console.log(`target: ${target}`, `way: ${way}`, `from: ${from}`);
    const textElement = target;

    const tl = gsap.timeline();

    tl.from(textElement, 1, {
      y: 100,
      ease: "power4.out",
      opacity: 0,
    });
  });

  function adjustScrollSpeed() {
    $(".loco-img").each(function () {
      var defaultSpeed = $(this).attr("data-default-speed") || "-0.2";
      var newSpeed;
      if ($(window).width() < 600) {
        newSpeed = "-0.05";
      } else if ($(window).width() >= 600 && $(window).width() < 1025) {
        newSpeed = "0";
      } else {
        newSpeed = defaultSpeed;
      }
      $(this).attr("data-scroll-speed", newSpeed);
    });
  }

  // Adjust on page load
  adjustScrollSpeed();

  // Adjust on window resize
  $(window).resize(adjustScrollSpeed);

  $("#your_country_origin").on("select2:open", function () {
    locomotiveScroll.destroy();
