  const hamIcon = document.querySelectorAll(".ham");
  const megaMenu = document.querySelector("#walkers-mega-menu");
  const megaClose = document.querySelector("#mega-close");

  hamIcon.forEach(ham => {
    ham.addEventListener("click",()=> {
      megaMenu.classList.add("active");
    });
  });

  megaClose.addEventListener("click",()=> {
    megaMenu.classList.remove("active");
      hamIcon.forEach(ham => {
      ham.classList.remove("is-active");
      locomotiveScroll = new LocomotiveScroll();

  });
  });


document.querySelectorAll("li.removed-anchor").forEach(li => {
  const anchor = li.querySelector("a");
  if (!anchor) return;

  const span = document.createElement("span");
  span.innerHTML = anchor.innerHTML;

  // Copy all classes from the anchor
  span.className = anchor.className;

  // Copy other attributes except href
  for (let { name, value } of anchor.attributes) {
    if (name !== "href") span.setAttribute(name, value);
  }

  // Replace the anchor with the span
  anchor.replaceWith(span);
});


document.getElementById("scroll-top").addEventListener("click", (e) => {
  e.preventDefault();
  window.scrollTo({
    top: 0,
    behavior: "smooth"
  });
});