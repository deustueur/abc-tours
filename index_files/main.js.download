document.addEventListener("DOMContentLoaded", function () {
  document
    .querySelectorAll(".menu-item-has-children")
    .forEach(function (menuItem) {
      const toggleButton = menuItem.querySelector(".toggle-btn-slide");
      const submenu = menuItem.querySelector(".submenu");

      if (!submenu || !toggleButton) return; // Skip if either is missing

      // Helper function to detect large screen
      function isLargeScreen() {
        return window.innerWidth > 1025;
      }

      // Helper to close all other submenus and remove toggle button active states
      function closeOtherSubmenus(currentSubmenu, currentToggle) {
        document
          .querySelectorAll(".submenu.show")
          .forEach(function (openSubmenu) {
            if (openSubmenu !== currentSubmenu) {
              new bootstrap.Collapse(openSubmenu, { toggle: false }).hide();
            }
          });

        document
          .querySelectorAll(".toggle-btn-slide.active")
          .forEach(function (btn) {
            if (btn !== currentToggle) {
              btn.classList.remove("active");
            }
          });
      }

      // Click event
      toggleButton.addEventListener("click", function (e) {
        e.stopPropagation(); // Prevent parent link click

        const collapse = new bootstrap.Collapse(submenu, { toggle: false });

        if (submenu.classList.contains("show")) {
          collapse.hide();
          toggleButton.classList.remove("active");
        } else {
          closeOtherSubmenus(submenu, toggleButton);
          collapse.show();
          toggleButton.classList.add("active");
        }
      });

      // Hover behavior for large screens only
      // menuItem.addEventListener("mouseenter", function () {
      //   if (isLargeScreen()) {
      //     const collapse = new bootstrap.Collapse(submenu, { toggle: false });

      //     closeOtherSubmenus(submenu, toggleButton);

      //     if (!submenu.classList.contains("show")) {
      //       collapse.show();
      //       toggleButton.classList.add("active");
      //     }
      //   }
      // });

      // menuItem.addEventListener("mouseleave", function () {
      //   if (isLargeScreen()) {
      //     const collapse = new bootstrap.Collapse(submenu, { toggle: false });
      //     collapse.hide();
      //     toggleButton.classList.remove("active");
      //   }
      // });
    });
});

