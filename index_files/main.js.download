jQuery(document).ready(function ($) {
  var locomotiveScroll = new LocomotiveScroll();

  const hams = document.querySelectorAll(".ham");
  const hamclose = document.querySelector(".hamclose");
  const menu = document.querySelector(".main-menu");
  const line = document.querySelector(".line");
  const links = menu.querySelectorAll("li");
  const overlay = document.querySelector(".menu-overlay"); // Select the overlay

  const tl = gsap.timeline({ paused: true });

  tl.to(overlay, {
    duration: 0.3,
    opacity: 1,
    visibility: "visible",
    ease: "expo.inOut",
  });

  const setMenuWidth = () => {
    let menuWidth = "30vw";

    if (window.innerWidth < 600) {
      menuWidth = "100%";
    } else if (window.innerWidth >= 600 && window.innerWidth < 1025) {
      menuWidth = "50%";
    }

    return menuWidth;
  };

  tl.to(menu, {
    duration: 0.5,
    opacity: 1,
    width: setMenuWidth(),
    ease: "expo.inOut",
    onStart: () => {
      menu.style.visibility = "visible"; // Change visibility to 'visible' when the animation starts
    },
    onReverseComplete: () => {
      menu.style.visibility = "hidden"; // Change visibility back to 'hidden' when the animation is reversed
    },
  });

  tl.from(
    line,
    {
      duration: 0.5,
      scaleX: 0, // Scale instead of width for smoother animation
      transformOrigin: "left center", // Expand from the left
      ease: "expo.inOut",
    },
    "-=0.5"
  );

  // tl.from(
  //   links,
  //   {
  //     duration: 0.5,
  //     opacity: 0,
  //     y: 20,
  //     stagger: 0.1,
  //     ease: "expo.inOut",
  //   },
  //   "-=0.5"
  // );
  // const animateLinks = () => {
  //   gsap.from(links, {
  //     duration: 0.5,
  //     opacity: 0,
  //     y: 20,
  //     stagger: 0.1,
  //     ease: "expo.inOut",
  //   });
  // };

  tl.reverse();

  hams.forEach((ham) => {
    ham.addEventListener("click", () => {
      tl.timeScale(1);
      tl.play();
      // animateLinks();
      hams.forEach((ham) => ham.classList.add("is-active"));
      hamclose.classList.add("is-active");
      locomotiveScroll.destroy();
    });
  });

  hamclose.addEventListener("click", () => {
    tl.timeScale(2.5);
    tl.reverse();
    hams.forEach((ham) => ham.classList.remove("is-active"));
    hamclose.classList.remove("is-active");
    locomotiveScroll = new LocomotiveScroll();
  });

  overlay.addEventListener("click", (e) => {
    if (!menu.contains(e.target)) {
      // Prevent closing if user clicks inside menu
      tl.timeScale(2.5);
      tl.reverse();
      hams.forEach((ham) => ham.classList.remove("is-active"));
      hamclose.classList.remove("is-active");
      locomotiveScroll = new LocomotiveScroll();
    }
  });

  const popup = document.getElementById("popup-overlay");

  if (popup) {
    const popId = popup.getAttribute("data-pop-id"); // get PHP ID
    const storageKey = "popupShown-" + popId;

    if (!sessionStorage.getItem(storageKey)) {
      // show popup if not already stored
      $("#popup-overlay").fadeIn();
      locomotiveScroll.destroy();
    }
  }

  $("#close-popup").on("click", function () {
    locomotiveScroll = new LocomotiveScroll();
  });

  // var textWrappers = document.querySelectorAll('.animate-title');

  // textWrappers.forEach((textWrapper) => {
  //     textWrapper.innerHTML = textWrapper.textContent.replace(/\S/g, "<span class='letter'>$&</span>");
